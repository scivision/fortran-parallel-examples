{
  "version": 6,

"configurePresets": [
{
  "name": "default",
  "binaryDir": "build",
  "generator": "Ninja",
  "cacheVariables": {
    "CMAKE_COMPILE_WARNING_AS_ERROR": true,
    "CMAKE_LINK_WARNING_AS_ERROR": true,
    "CMAKE_BUILD_TYPE": "Release"
  }
},
{ "name": "build", "inherits": "default" }
],
"buildPresets": [
  { "name": "default", "configurePreset": "default", "configuration": "Release" },
  { "name": "build", "configurePreset": "build", "inherits": "default" }
],
"testPresets": [
{
  "name": "default",
  "configurePreset": "default",
  "configuration": "Release",
  "output": {
    "outputOnFailure": true,
    "verbosity": "verbose"
  },
  "execution": {
    "noTestsAction": "error",
    "scheduleRandom": true,
    "stopOnFailure": false
  }
}
],
"workflowPresets": [
  {
    "name": "default",
    "steps": [
      { "type": "configure", "name": "default" },
      { "type": "build", "name": "default" },
      { "type": "test", "name": "default" }
    ]
  },
  {
    "name": "build",
    "steps": [
      { "type": "configure", "name": "build" },
      { "type": "build", "name": "build" }
    ]
  }
]
}
